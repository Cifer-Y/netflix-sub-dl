{
  "manifest_version": 3,
  "name": "Netflix Subtitle Downloader",
  "version": "1.0.0",
  "description": "Download Netflix subtitles as SRT files",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://*.nflxvideo.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["parser.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
